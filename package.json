{
  "name": "prism",
  "version": "0.1.0",
  "private": true,
  "description": "Collaborative sense-making platform that decomposes complex questions into explorable claim graphs",
  "scripts": {
    "dev": "pnpm --parallel --filter @prism/client --filter @prism/server dev",
    "dev:client": "pnpm --filter @prism/client dev",
    "dev:server": "pnpm --filter @prism/server dev",
    "build": "pnpm --filter @prism/shared build && pnpm --parallel --filter @prism/client --filter @prism/server build",
    "test": "pnpm --recursive test",
    "test:client": "pnpm --filter @prism/client test",
    "test:server": "pnpm --filter @prism/server test",
    "test:e2e": "pnpm --filter @prism/client test:e2e",
    "eval": "pnpm --filter @prism/eval run evaluate",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint",
    "db:migrate": "pnpm --filter @prism/server db:migrate",
    "db:seed": "pnpm --filter @prism/server db:seed",
    "db:reset": "pnpm --filter @prism/server db:reset",
    "clean": "pnpm --recursive clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
