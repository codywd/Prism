# AI Provider ("anthropic" or "openai-compatible")
AI_PROVIDER=openai-compatible

# Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI-compatible / LM Studio (when AI_PROVIDER=openai-compatible)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=lm-studio
OPENAI_COMPATIBLE_MODEL=                        # fallback used for all roles unless overridden below
OPENAI_COMPATIBLE_DECOMPOSE_MODEL=              # optional — overrides OPENAI_COMPATIBLE_MODEL for decompose
OPENAI_COMPATIBLE_AUDIT_MODEL=                  # optional — overrides OPENAI_COMPATIBLE_MODEL for audit
OPENAI_COMPATIBLE_EXPAND_MODEL=                 # optional — overrides OPENAI_COMPATIBLE_MODEL for expand

# Model overrides (Anthropic only)
AI_DECOMPOSE_MODEL=claude-opus-4-6
AI_EXPAND_MODEL=claude-sonnet-4-6
AI_AUDIT_MODEL=claude-sonnet-4-6

# Temperature (both providers)
AI_TEMPERATURE_DECOMPOSE=0.3
AI_TEMPERATURE_EXPAND=0.3
AI_TEMPERATURE_AUDIT=0.2

# Databases (Phase 2+)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# Auth (Phase 2+)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Application
LOG_LEVEL=info
MAX_GRAPH_NODES=500
RATE_LIMIT_QUESTIONS_PER_HOUR=10
